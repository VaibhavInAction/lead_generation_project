# LeadForge configuration — copy to .env and edit. Never commit .env.
# Every variable is optional; the defaults shown here are the built-in defaults.

# --- Database -----------------------------------------------------------
# Swap to postgresql://user:pass@host/db in later phases without code changes.
DATABASE_URL=sqlite:///data/leadforge.db

# --- Sources ------------------------------------------------------------
# Comma-separated kill switch. v0.1: linkedin_posts. Later: reddit, linkedin, job_boards.
SOURCES_ENABLED=linkedin_posts

# --- Scraping conduct (see README §6 — these are compliance controls) ----
SCRAPE_DELAY_MIN=8
SCRAPE_DELAY_MAX=15
SCRAPE_DAILY_CAP=150
SCRAPE_HEADLESS=true
# Consecutive authwalls/CAPTCHAs that cleanly abort a run (kill switch).
SCRAPE_AUTHWALL_LIMIT=5
# Persist checkpoint progress after every N extracted leads (enables --resume).
SCRAPE_CHECKPOINT_EVERY=5
# Max retries for a transient (timeout/5xx) request failure.
SCRAPE_MAX_RETRIES=3
# Phrase templates for intent mining (see README §13.1).
INTENT_QUERIES_PATH=intent_queries.yaml
# Your agency's target services, scraped together by `intent scrape-all` (README §14).
NEEDS_PATH=needs.yaml

# --- Search discovery (see README §13.1) --------------------------------
# serper (Google results as JSON, free, no card — default)
#   | brave (JSON API, requires a card) | ddg (HTML scraping, soft-blocks; fallback only)
SEARCH_ENGINE=serper
# Country weighting for Google results (gl code): us = USA, in = India, gb = UK ...
SEARCH_COUNTRY=us
# Required when SEARCH_ENGINE=serper. Free key (no card) at https://serper.dev
SERPER_API_KEY=
# Required when SEARCH_ENGINE=brave. Key at https://brave.com/search/api/ (needs a card)
BRAVE_API_KEY=

# --- Local AI (optional; platform is fully functional with this off) -----
AI_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
# console (human-readable) | json (machine-readable)
LOG_FORMAT=console

# --- Output ---------------------------------------------------------------
EXPORT_DIR=exports
